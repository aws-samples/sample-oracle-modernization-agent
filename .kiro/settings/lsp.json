{
  "languages": {
    "python": {
      "name": "python",
      "file_extensions": [".py"],
      "project_patterns": ["pyproject.toml", "setup.py", "requirements.txt"],
      "exclude_patterns": ["**/node_modules/**", "**/.git/**", "**/venv/**", "**/__pycache__/**"],
      "command": "pyright-langserver",
      "args": ["--stdio"]
    }
  }
}
